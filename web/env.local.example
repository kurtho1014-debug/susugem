# ══════════════════════════════════════════════════════════════
#  SUSU 環境變數範本
#  複製此檔為 .env.local，填入實際值後啟動
# ══════════════════════════════════════════════════════════════

# ── 本機開發（Docker self-hosted）─────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...（docker-compose 裡的 ANON_KEY）

# ── 線上部署（Supabase Cloud）─────────────────────────────────
# 到 https://supabase.com → 你的專案 → Settings → API 複製
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── 圖片上傳（Supabase Storage service role）──────────────────
# 在 Settings → API 找 service_role key
# ⚠️  此 key 有完整權限，只能放在 server-side（.env.local 不會推上 GitHub）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
